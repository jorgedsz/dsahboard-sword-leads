PORT=3001
# ID de la Google Sheet (la parte entre /d/ y /edit en la URL)
SHEET_ID=1lf3EK7vo3lUnx8uOMZvSnooshiZvboIjcurPasxMEl8
# gid de la pestaña a leer (0 = primera pestaña)
SHEET_GID=0
# Segundos que se cachea la respuesta de Google
CACHE_SECONDS=15

# ─── Reenvío de leads "Registered" a n8n ───
# URL del webhook de n8n. Vacío = reenvío desactivado.
N8N_WEBHOOK_URL=
# Estado que dispara el envío
TRIGGER_STATUS=Registered
# Cada cuántos segundos se revisa la hoja
POLL_SECONDS=30
# Columna identificadora del lead (anti-duplicados)
LEAD_ID_COLUMN=LEAD_ID

# ─── Imágenes de anuncios (Meta Marketing API) ───
# Token con permiso ads_read. Vacío = desactivado.
META_ACCESS_TOKEN=
META_API_VERSION=v21.0
META_CACHE_MINUTES=60
# Minutos de caché para insights (gasto/rendimiento)
META_INSIGHTS_CACHE_MINUTES=15
